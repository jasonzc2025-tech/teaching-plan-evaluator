# OpenAI-compatible inference API settings
LLM_API_KEY=replace-with-your-new-key
LLM_API_BASE=https://api.deepseek.com/v1/chat/completions
LLM_MODEL_NAME=deepseek-chat
LLM_TIMEOUT_SEC=300

# Flask settings
SECRET_KEY=replace-with-a-long-random-string
ADMIN_PASSWORD=change-me
DB_PATH=/app/instance/eval_records.db
MAX_CONTENT_LENGTH_MB=20

# 仅排障：为 true 时 /evaluate 对服务端异常返回详细错误（生产勿开）
EVAL_EXPOSE_INTERNAL_ERRORS=false
