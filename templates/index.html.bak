{% extends "base.html" %}
{% block title %}住培临床教案质量智能评审系统{% endblock %}
{% block body %}

<div class="topbar">
  <div class="container topbar-inner">
    <div class="topbar-brand">
      <div class="topbar-icon">📋</div>
      <div>
        <h1>住培临床教案质量智能评审系统</h1>
        <div class="topbar-tags">
          <span class="topbar-tag">V3.0</span>
          <span class="topbar-tag">五类教案</span>
          <span class="topbar-tag">百分制</span>
          <span class="topbar-tag">条款级证据驱动</span>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="container page-grid">

  <!-- 左栏：提交表单 -->
  <div>
    <!-- 教案类型 -->
    <div class="card">
      <div class="card-header">
        <div class="card-icon">📑</div>
        <h2>教案类型</h2>
      </div>
      <div class="type-selector" id="type-selector">
        <button class="type-btn active" data-value="">自动识别</button>
        <button class="type-btn" data-value="教学查房">教学查房</button>
        <button class="type-btn" data-value="病例讨论">病例讨论</button>
        <button class="type-btn" data-value="临床小讲课">临床小讲课</button>
        <button class="type-btn" data-value="技能培训">技能培训</button>
        <button class="type-btn" data-value="教学门诊">教学门诊</button>
      </div>
      <input type="hidden" id="declared-type-input" value="">
    </div>

    <!-- 上传教案 -->
    <div class="card">
      <div class="card-header">
        <div class="card-icon">📎</div>
        <h2>上传教案</h2>
      </div>

      <div class="upload-zone" id="upload-zone">
        <input type="file" id="file-input" accept=".docx,.pdf,.txt,.doc">
        <div class="upload-icon">📂</div>
        <div class="upload-hint">
          <strong>点击或拖拽文件到此处</strong>
          <small>支持 .docx · .pdf · .txt，最大 20MB</small>
        </div>
      </div>

      <div class="file-selected" id="file-selected">
        <span>✅</span>
        <span class="file-selected-name" id="file-selected-name"></span>
        <button class="btn sm" onclick="clearFile()" style="border-color:var(--line);font-size:11px;padding:4px 10px;">清除</button>
      </div>

      <!-- 自动解析的元数据 -->
      <div class="meta-parsed" id="meta-parsed">
        <div class="meta-item">
          <div class="meta-item-label">科室</div>
          <div class="meta-item-value" id="meta-dept">—</div>
        </div>
        <div class="meta-item">
          <div class="meta-item-label">带教老师</div>
          <div class="meta-item-value" id="meta-teacher">—</div>
        </div>
        <div class="meta-item">
          <div class="meta-item-label">课程名称</div>
          <div class="meta-item-value" id="meta-course">—</div>
        </div>
        <div class="meta-item">
          <div class="meta-item-label">评审轮次</div>
          <div class="meta-item-value" id="meta-round">第 1 轮</div>
        </div>
      </div>

      <div class="divider">或粘贴教案文字</div>

      <textarea id="text-content" rows="6" placeholder="将教案文字内容粘贴到此处..."></textarea>

      <div style="margin-top:16px;">
        <button class="btn primary" id="submit-btn" onclick="submitEval()">
          <span id="submit-icon">🔍</span>
          <span id="submit-text">开始分析</span>
        </button>
      </div>

      <div class="notice-bar">
        📌 本系统仅记录评审类型、分数等统计数据，<strong>不保存教案原文内容</strong>。教案文本经加密传输处理后即时丢弃，不作留存。
      </div>
    </div>

    <!-- 使用说明 -->
    <div class="card">
      <div class="card-header">
        <div class="card-icon">ℹ️</div>
        <h2>使用说明</h2>
      </div>
      <ul style="list-style:none;display:flex;flex-direction:column;gap:8px;font-size:13px;color:var(--muted);">
        <li>📖 依据国家《住培教学活动指南》评审</li>
        <li>📊 百分制条款评分，每分有证据依据</li>
        <li>📄 建议提交 Word .docx 文件效果最佳</li>
        <li>⚡ 结果实时生成，无需等待</li>
        <li>🔒 科室、老师等信息从文件名自动识别</li>
      </ul>
    </div>
  </div>

  <!-- 右栏：结果 -->
  <div>
    <div class="card" style="min-height:520px;">
      <div class="card-header">
        <div class="card-icon">📊</div>
        <h2>评审结果</h2>
        <span id="result-type-badge" style="margin-left:auto;font-size:12px;color:var(--muted);"></span>
      </div>

      <!-- 初始占位 -->
      <div id="placeholder" class="placeholder">
        <div class="placeholder-icon">🗒️</div>
        <p>上传教案后点击「开始分析」<br>总分、问题分类与修改建议将在此显示</p>
      </div>

      <!-- 流式输出 -->
      <div id="stream-box" class="hidden">
        <div class="stream-header">
          <span class="stream-dot"></span>
          正在分析中，报告实时生成...
        </div>
        <pre id="stream-text" class="stream-text"></pre>
      </div>

      <!-- 最终结果 -->
      <div id="result-panel" class="hidden">
        <!-- 评分概览 -->
        <div class="score-header" id="score-header"></div>
        <!-- 结论横幅 -->
        <div id="conclusion-banner" class="conclusion-banner"></div>

        <!-- 问题列表 -->
        <div class="subcard">
          <h3>⚠️ 问题列表</h3>
          <div id="issue-list"></div>
        </div>

        <!-- 条款得分 -->
        <div class="subcard">
          <h3>📋 条款得分明细</h3>
          <div id="clause-table"></div>
        </div>

        <!-- 报告正文 -->
        <div class="subcard">
          <h3>📝 完整报告</h3>
          <pre id="markdown-box" class="markdown-box"></pre>
        </div>
      </div>

      <div id="error-box" class="error-box hidden"></div>
    </div>
  </div>
</div>

<script>
// ─── 类型选择 ───
document.querySelectorAll('.type-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.type-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('declared-type-input').value = btn.dataset.value;
  });
});

// ─── 文件上传 & 元数据解析 ───
const fileInput = document.getElementById('file-input');
const uploadZone = document.getElementById('upload-zone');
const fileSelected = document.getElementById('file-selected');
const fileSelectedName = document.getElementById('file-selected-name');
const metaParsed = document.getElementById('meta-parsed');

uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('drag-over'); });
uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('drag-over'));
uploadZone.addEventListener('drop', e => {
  e.preventDefault();
  uploadZone.classList.remove('drag-over');
  if (e.dataTransfer.files[0]) { fileInput.files = e.dataTransfer.files; handleFileChange(); }
});
fileInput.addEventListener('change', handleFileChange);

function handleFileChange() {
  const file = fileInput.files[0];
  if (!file) return;
  fileSelectedName.textContent = file.name + '  (' + (file.size / 1024).toFixed(0) + ' KB)';
  fileSelected.classList.add('show');
  uploadZone.style.display = 'none';
  parseFilenameMetadata(file.name);
  metaParsed.classList.add('show');
}

function clearFile() {
  fileInput.value = '';
  fileSelected.classList.remove('show');
  uploadZone.style.display = '';
  metaParsed.classList.remove('show');
}

// 从文件名解析元数据
// 常见格式：病例讨论07-消化内科-陈辰-腹水待查.docx
//           小讲课92-心内科-欧子明-高血压.docx
function parseFilenameMetadata(filename) {
  const name = filename.replace(/\.(docx?|pdf|txt)$/i, '');
  const parts = name.split(/[-_]/);

  let dept = '—', teacher = '—', course = '—';

  if (parts.length >= 4) {
    // 格式：类型+编号 - 科室 - 老师 - 课程名
    dept    = parts[1] ? parts[1].trim() : '—';
    teacher = parts[2] ? parts[2].trim() : '—';
    course  = parts.slice(3).join('-').trim() || '—';
  } else if (parts.length === 3) {
    dept    = parts[0].trim();
    teacher = parts[1].trim();
    course  = parts[2].trim();
  } else if (parts.length === 2) {
    dept   = parts[0].trim();
    course = parts[1].trim();
  } else {
    course = name;
  }

  document.getElementById('meta-dept').textContent    = dept;
  document.getElementById('meta-teacher').textContent = teacher;
  document.getElementById('meta-course').textContent  = course;

  // 查询该文件名的历史评审次数来推算轮次（前端暂用文件名匹配本地存储）
  // 这里简单地每次重置为 1，轮次由后台实际记录统计
  document.getElementById('meta-round').textContent = '第 1 轮（后台自动统计）';
}

// ─── 辅助 ───
function escapeHtml(text) {
  return (text || '').replace(/[&<>"']/g, m =>
    ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[m]);
}

function badgeClass(severity) {
  return { fatal:'badge-fatal', major:'badge-major', minor:'badge-minor', note:'badge-note' }[severity] || 'badge-default';
}

function conclusionClass(conclusion, vetoed) {
  if (vetoed) return 'fail';
  if (!conclusion) return 'warn';
  if (conclusion.includes('良好') || conclusion.includes('优秀')) return 'pass';
  if (conclusion.includes('合格')) return 'warn';
  return 'fail';
}

function renderResult(data) {
  const summary = data.summary || {};

  // 类型标签
  document.getElementById('result-type-badge').textContent =
    summary.actual_type || summary.declared_type || '';

  // 评分 KPI
  document.getElementById('score-header').innerHTML = `
    <div class="score-kpi">
      <div class="label">通用维度</div>
      <div class="value">${summary.score_general ?? '—'}</div>
      <div class="sub">满分 ${summary.score_general_max ?? 45}</div>
    </div>
    <div class="score-kpi">
      <div class="label">分项维度</div>
      <div class="value">${summary.score_specific ?? '—'}</div>
      <div class="sub">满分 ${summary.score_specific_max ?? 55}</div>
    </div>
    <div class="score-kpi" style="background:var(--blue-mid);color:#fff;">
      <div class="label" style="color:rgba(255,255,255,0.75);">总分</div>
      <div class="value" style="color:#fff;">${summary.score_total ?? '—'}</div>
      <div class="sub" style="color:rgba(255,255,255,0.7);">满分 100</div>
    </div>
  `;

  // 结论横幅
  const cls = conclusionClass(summary.conclusion, summary.vetoed);
  const icon = { pass:'✅', warn:'⚠️', fail:'❌' }[cls];
  document.getElementById('conclusion-banner').innerHTML =
    `<span>${icon}</span><span>${summary.vetoed ? '已否决 · ' : ''}${summary.conclusion || '评审完成'}</span>`;
  document.getElementById('conclusion-banner').className = `conclusion-banner ${cls}`;

  // 问题列表
  const issues = data.issues || [];
  document.getElementById('issue-list').innerHTML = issues.length
    ? issues.map(item => `
        <div class="issue-item">
          <div class="issue-head">
            <span class="badge ${badgeClass(item.severity)}">${escapeHtml(item.severity || 'minor')}</span>
            <strong>${escapeHtml(item.issue_category || '未分类')}</strong>
            <span style="color:var(--muted);font-size:12px;">${escapeHtml(item.clause_name || '')}</span>
          </div>
          <div style="margin-bottom:4px;">${escapeHtml(item.issue_text || '')}</div>
          <div style="color:var(--muted);font-size:12px;">📍 ${escapeHtml(item.evidence_position || '—')}</div>
          <div style="color:var(--muted);font-size:12px;margin-top:2px;">💡 ${escapeHtml(item.suggestion_text || '—')}</div>
        </div>
      `).join('')
    : '<div style="color:var(--muted);padding:8px 0;">未提取到结构化问题，请参考下方完整报告。</div>';

  // 条款得分
  const clauses = data.clause_scores || [];
  document.getElementById('clause-table').innerHTML = clauses.length
    ? `<table class="table">
        <thead><tr><th>条款</th><th>满分</th><th>实得</th><th>证据</th><th>说明</th></tr></thead>
        <tbody>${clauses.map(c => `
          <tr>
            <td>${escapeHtml(c.clause_name || c.clause_code || '—')}</td>
            <td>${escapeHtml(String(c.max_score ?? '—'))}</td>
            <td><strong style="color:var(--blue-mid)">${escapeHtml(String(c.actual_score ?? '—'))}</strong></td>
            <td style="color:var(--muted)">${escapeHtml(c.evidence_position || '—')}</td>
            <td>${escapeHtml(c.judgment_text || '—')}</td>
          </tr>`).join('')}
        </tbody>
      </table>`
    : '<div style="color:var(--muted);">暂无条款数据。</div>';

  document.getElementById('markdown-box').textContent = data.result_markdown || '';

  document.getElementById('stream-box').classList.add('hidden');
  document.getElementById('result-panel').classList.remove('hidden');
}

// ─── 提交评审 ───
async function submitEval() {
  const btn = document.getElementById('submit-btn');
  const submitText = document.getElementById('submit-text');
  const submitIcon = document.getElementById('submit-icon');

  btn.disabled = true;
  submitIcon.textContent = '⏳';
  submitText.textContent = '分析中...';

  document.getElementById('error-box').classList.add('hidden');
  document.getElementById('placeholder').classList.add('hidden');
  document.getElementById('result-panel').classList.add('hidden');
  document.getElementById('stream-box').classList.remove('hidden');
  document.getElementById('stream-text').textContent = '';

  try {
    const formData = new FormData();
    const file = document.getElementById('file-input').files[0];
    if (file) formData.append('file', file);

    const textContent = document.getElementById('text-content').value.trim();
    if (textContent) formData.append('text_content', textContent);

    formData.append('declared_type', document.getElementById('declared-type-input').value);

    // 从解析的元数据传入
    formData.append('department',   document.getElementById('meta-dept').textContent.replace('—',''));
    formData.append('teacher_name', document.getElementById('meta-teacher').textContent.replace('—',''));
    formData.append('course_title', document.getElementById('meta-course').textContent.replace('—',''));
    formData.append('review_round', '1');

    const response = await fetch('/evaluate_stream', { method: 'POST', body: formData });
    if (!response.ok) throw new Error(`HTTP ${response.status}`);

    const reader = response.body.getReader();
    const decoder = new TextDecoder('utf-8');
    let buffer = '';
    let finalData = null;

    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      buffer += decoder.decode(value, { stream: true });
      const lines = buffer.split('\n');
      buffer = lines.pop();

      for (const line of lines) {
        if (!line.startsWith('data: ')) continue;
        const raw = line.slice(6).trim();
        if (!raw) continue;
        try {
          const chunk = JSON.parse(raw);
          if (chunk.error) throw new Error(chunk.error);
          if (chunk.token !== undefined) {
            document.getElementById('stream-text').textContent += chunk.token;
            document.getElementById('stream-text').scrollTop = 99999;
          }
          if (chunk.done) finalData = chunk;
        } catch(e) {
          if (e.message && !e.message.includes('JSON')) throw e;
        }
      }
    }

    if (finalData) {
      renderResult(finalData);
    } else {
      throw new Error('未收到完整评审结果，请重试。');
    }

  } catch (err) {
    document.getElementById('stream-box').classList.add('hidden');
    document.getElementById('placeholder').classList.remove('hidden');
    document.getElementById('error-box').textContent = '❌ ' + err.message;
    document.getElementById('error-box').classList.remove('hidden');
  } finally {
    btn.disabled = false;
    submitIcon.textContent = '🔍';
    submitText.textContent = '开始分析';
  }
}
</script>
{% endblock %}
